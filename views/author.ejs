<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width= , initial-scale=1.0">
   <link rel="stylesheet" href="/main.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet"/>
     <script src="//maxcdn.bootstrapcdn.com/bootstrap/4.1.1/js/bootstrap.min.js"></script>
    <title>portfolio</title>
</head>

<body>
    <div class="frame">
        <div class="main_frame">
            <div class="left_frame">
                <div class="left_1">
                    <div class="left_1_1">
                        <img src="images/profile.png" width="156px" height="142px" alt="--">
                    </div>
                    <div class="left_1_2">
                        <%= user.name %>
                    </div>
                    <div class="left_1_3">
                        <%= user.profession %>
                    </div>
                    <div class="left_icons">
                        <a class="link_href" href="">
                            <div class="icon">
                                <img src="icon/facebook.svg" class="icon_1"/>
                            </div>
                        </a>  <a class="link_href" href="">
                            <div class="icon">
                                <img src="icon/x.svg" class="icon_1"/>
                            </div>
                        </a>
                          <a class="link_href" href="">
                            <div class="icon">
                                <img src="icon/youtube.svg" class="icon_1"/>
                            </div>
                        </a>
                          <a class="link_href" href="">
                            <div class="icon">
                                <img src="icon/linkedin.svg" class="icon_1"/>
                            </div>
                        </a>
                          <a class="link_href" href="">
                            <div class="icon">
                                <img src="icon/instagram.svg" class="icon_1"/>
                            </div>
                        </a>
                    </div>
                </div> 
                <div class="marginer"></div>

                
                <div class="left_2">
                    <div class="about_me">
                        <div class="age">Age:</div>
                        <div class="age_number"><%= user.age %></div>
                    </div>

                     <div class="about_me">
                        <div class="residence">Residence:</div>
                        <div class="residence_1"><%= user.residence %></div>
                    </div>

                     <div class="about_me">
                        <div class="freelance">Freelance:</div>
                        <div class="freelance_1">Available</div>
                    </div>

                     <div class="about_me">
                        <div class="address">Address:</div>
                        <div class="address_1"><%= user.address %></div>
                    </div>
                </div>
                <div class="marginer"></div>

                <div class="left_3">
                    <div class="languages">
                        <h2>Languages</h2>
                    </div>
                </div>
                <div class="marginer"></div>
                <div class="left_4"></div>
                <div class="marginer"></div>
                <div class="left_5"></div>
                <div class="marginer"></div>


            </div>
            <div class="midd_frame"></div>
            <div class="right_frame"></div>
        </div>
    </div>
    

</body>



</html>